
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
# Local dev: http://localhost:5173
# Production: https://syncboardpro.netlify.app
# You can add multiple allowed origins by separating them with commas.
CLIENT_URL=http://localhost:5173,https://syncboardpro.netlify.app

WORKER_URL=https://your-worker.workers.dev
# Render will provide PORT automatically, but 3001 is fine for local runs.
PORT=3001
NODE_ENV=production

ADMIN_SECRET=change-me-to-a-long-random-string
PUSHOVER_TOKEN=
PUSHOVER_USER_KEY=
